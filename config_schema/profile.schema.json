{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fitom-profile",
  "title": "FITOM プロファイル (*.profile.json)",
  "description": "エンドユーザーが通常運用で設定するデバイス構成・MIDI マッピング等。複数プロファイルを切り替えて使用できる。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_name"
  ],
  "properties": {
    "profile_name": {
      "type": "string",
      "description": "このプロファイルの表示名。GUI のプロファイル選択リストに使用する。",
      "examples": [
        "自宅スタジオ (SPFM + OPN2)",
        "エミュレーター (OPM + OPL3)"
      ]
    },
    "devices": {
      "type": "array",
      "description": "論理デバイス定義。FITOM の MIDIチャンネル割り当てに使用される。エミュレーターとハードウェアを混在させることができる。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "if",
          "plugin"
        ],
        "properties": {
          "if": {
            "type": "string",
            "enum": [
              "HW"
            ],
            "description": "バックエンド種別。実機/エミュレータ問わず全て\"HW\"を使う (FITOM本体は両者を区別しない、hw_plugins[]で使うプラグインを指定する)。"
          },
          "label": {
            "type": "string",
            "description": "このデバイスの表示名（GUI 表示用・任意）。",
            "examples": [
              "OPNA #1",
              "OPL3 (エミュ)"
            ]
          },
          "chip": {
            "type": "string",
            "description": "チップ種別文字列。resolveChipDeviceId()でDEVICE_*に変換される。HWプラグイン(FitomEmuIF等)のparams_jsonの一部として転送される場合もある。",
            "examples": [
              "OPNA",
              "OPM",
              "OPL3",
              "SSG",
              "DCSG"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "RE1",
              "RE4",
              "SPFM_TOWER",
              "SPFM_LIGHT",
              "FMHWIF"
            ],
            "description": "[if=HW のみ] ハードウェアインターフェース種別。RE1/RE4/SPFM_TOWER/SPFM_LIGHTは物理ハードウェア、FMHWIFはFmEngineベースのエミュレータ統合プラグイン(FitomEmuIF等)を指す。FITOM本体はこの値を各プラグインへの不透明なパラメータとしてのみ扱い、実機かエミュレータかで処理を分岐させることはない。"
          },
          "serial": {
            "type": "string",
            "description": "[if=HW, type=RE1/RE4 のみ] FT245R/FT2232H のシリアル番号。省略時は index=0 のデバイスを使用する。",
            "examples": [
              "ABCD1234"
            ]
          },
          "port": {
            "type": "string",
            "description": "[if=HW, type=SPFM_* のみ] COMポート名または /dev/ttyUSB* のパス。",
            "examples": [
              "COM3",
              "/dev/ttyUSB0"
            ]
          },
          "slot": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "maximum": 15,
            "description": "[if=HW のみ] SPFM スロット番号。RE1/RE4 は常に 0。"
          },
          "hw_clock": {
            "type": "integer",
            "default": 0,
            "description": "[if=HW のみ] チップのマスタークロック [Hz]。0 は呼び出し元が管理しない（チップドライバが固定値を持つ場合）。",
            "examples": [
              3993600,
              3579545,
              8000000
            ]
          },
          "pan": {
            "type": "integer",
            "default": 0,
            "enum": [
              0,
              1,
              2,
              3
            ],
            "description": "[if=HW のみ] パノラマ。0=Stereo, 1=L only, 2=R only, 3=LR mono。"
          },
          "extra_slot": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "[if=HW, type=SPFM_* のみ] 2 ポートチップ (OPNA/OPN2/OPL3 等) の 2 ポート目に使う SPFM スロット番号。省略時は 1 ポートとして動作 (エミュレーター時は不要)。SplitPort が port1(slot) と port2(extra_slot) を統合し、チップドライバは addr >= 0x100 を port2 向けとして透過的に書くだけでよい。"
          },
          "dll": {
            "type": "string",
            "description": "[if=HW のみ] 使用する HW プラグイン DLL のパス（またはファイル名）。省略時は setHWPlugin() で登録した既定の DLL を使用する。同一パスが複数のデバイスから参照された場合、DLL インスタンスは共有される。",
            "examples": [
              "fitom_hw.dll",
              "fitom_fmhwif.dll",
              "../build/Release/fitom_hw.dll"
            ]
          },
          "sample_rate": {
            "type": "integer",
            "default": 44100,
            "description": "[if=HW のみ] サンプルレート [Hz]。fitom_fmhwif.dll および fitom_hw.dll の遅延キュー計算に使用する。省略時は 44100。",
            "examples": [
              44100,
              48000
            ]
          },
          "rhythm_mode": {
            "type": "boolean",
            "default": false,
            "description": "OPLL/OPL/OPL2/OPL3/OPNA等、チップ内蔵リズム音源の有効/無効。有効時はsub-device自動生成によりリズム専用デバイスが追加生成される。"
          },
          "stereo_pair": {
            "type": "boolean",
            "default": false,
            "description": "リニアステレオ化 (CLinearPanDevice) の対象として明示指定する。同一VoicePatchType・同一I/F・pan(1=L)とpan(2=R)の組み合わせを持つ2エントリのみ、自動的にステレオデバイスとして統合される。自動検出はせず、両エントリともこのフラグが必要。"
          },
          "plugin": {
            "type": "string",
            "description": "if=\"HW\"の場合に使うHWプラグイン名。hw_plugins[].nameから参照する。実機・エミュレータ問わず同じフィールドで指定する。",
            "examples": [
              "FitomEmuIF",
              "SpfmDriver"
            ]
          },
          "index": {
            "type": "integer",
            "description": "if=\"HW\"かつFitomEmuIF等のエミュレータプラグインを使う場合のチップインスタンス番号。プラグインのfmhwif_profile.json等、プラグイン自身の設定で複数チップインスタンスを持つ場合にどれを使うかを指定する。",
            "examples": [
              0,
              1
            ]
          },
          "engine": {
            "type": "string",
            "description": "[if=HW かつ FitomEmuIF等のFmEngineベースのプラグインを使う場合] そのHWプラグイン自身の設定(例: FitomEmuIFのfmhwif_profile.json)に登録されたFmEngine名。FITOM_X本体はこの値を単にparams_jsonの一部としてプラグインに転送するのみで、自身でFmEngineをロードすることはない。",
            "examples": [
              "YMEngine",
              "AYEngine"
            ]
          }
        }
      }
    },
    "midi_inputs": {
      "type": "array",
      "description": "使用する MIDI 入力デバイス名の一覧。MidiPlugin_EnumerateIn() が返すデバイス名と一致させること。",
      "items": {
        "type": "string"
      },
      "examples": [
        [
          "MIDI キーボード",
          "UM-ONE"
        ]
      ]
    },
    "midi_outputs": {
      "type": "array",
      "description": "使用する MIDI 出力デバイス名の一覧（MIDI スルー等に使用）。省略可。",
      "items": {
        "type": "string"
      },
      "examples": [
        [
          "External Synth Out"
        ]
      ]
    },
    "banks": {
      "type": "object",
      "description": "バンクファイルの読み込み設定。",
      "additionalProperties": false,
      "properties": {
        "hw_banks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "group",
              "bank",
              "file"
            ],
            "properties": {
              "group": {
                "type": "string",
                "enum": [
                  "OPM",
                  "OPN",
                  "OPL2",
                  "OPL3",
                  "OPLL",
                  "PSG",
                  "PCM"
                ]
              },
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127
              },
              "file": {
                "type": "string"
              }
            }
          }
        },
        "sw_banks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "bank",
              "file"
            ],
            "properties": {
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127
              },
              "file": {
                "type": "string"
              }
            }
          }
        },
        "patch_banks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "bank",
              "file"
            ],
            "properties": {
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127
              },
              "file": {
                "type": "string"
              }
            }
          }
        },
        "drum_banks": {
          "type": "array",
          "description": "ドラムバンクファイル一覧 (CRhythmCh 用)。MIDI CC#0 でバンクを切り替える。",
          "items": {
            "type": "object",
            "required": [
              "bank",
              "file"
            ],
            "properties": {
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "ドラムバンク番号 (MIDI CC#0)"
              },
              "file": {
                "type": "string",
                "description": "*.drumbank.json のファイルパス"
              }
            }
          }
        },
        "scc_wave_banks": {
          "type": "array",
          "description": "SCC/SCC+ 波形バンクファイル一覧。HwPatch の WS フィールドで波形番号を指定する。",
          "items": {
            "type": "object",
            "required": [
              "bank",
              "file"
            ],
            "properties": {
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "波形バンク番号。デバイスに setWaveBankNo() で指定する。"
              },
              "file": {
                "type": "string",
                "description": "*.sccwave.json のパス。"
              }
            }
          }
        },
        "pcm_banks": {
          "type": "array",
          "description": "PCM/ADPCM バンクファイル一覧。HwPatch の WS フィールドでエントリ番号を指定する。",
          "items": {
            "type": "object",
            "required": [
              "bank",
              "file"
            ],
            "properties": {
              "bank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "PCM バンク番号。デバイスに setPcmRegistry() で渡される。"
              },
              "file": {
                "type": "string",
                "description": "*.pcmbank.json のパス。"
              }
            }
          }
        }
      }
    },
    "midi_backend": {
      "type": "object",
      "description": "MIDI入力バックエンドDLL(WinMM/ALSA等)の指定。省略時はプラットフォーム既定(Windows: fitom_midi_winmm、Linux: fitom_midi_alsa)を実行ファイルと同じディレクトリから探索する。",
      "additionalProperties": false,
      "properties": {
        "dll": {
          "type": "string",
          "description": "MIDIバックエンドDLLのファイル名またはパス。相対パスの場合は実行ファイルのディレクトリを基点とする。",
          "examples": [
            "fitom_midi_winmm.dll",
            "fitom_midi_alsa.so",
            "fitom_midi_wms.dll"
          ]
        }
      }
    },
    "hw_plugins": {
      "type": "array",
      "description": "使用するHWプラグインDLL(IHWPlugin実装)の一覧。実機ハードウェア用プラグインとエミュレーター統合プラグイン(FitomEmuIF等)を問わず、同じ形式で複数登録できる。FITOM本体はエミュレータか実機かを一切区別しない。devices[]側のpluginフィールドから名前で参照する。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "dll"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "プラグイン識別名。devices[]のpluginフィールドから参照される。",
            "examples": [
              "FitomEmuIF",
              "SpfmDriver"
            ]
          },
          "dll": {
            "type": "string",
            "description": "IHWPlugin実装DLLのファイル名またはパス。"
          }
        }
      }
    }
  },
  "examples": [
    {
      "profile_name": "エミュレーター (OPM + OPL3 + SSG)",
      "hw_plugins": [
        {
          "name": "FitomEmuIF",
          "dll": "FitomEmuIF.dll"
        }
      ],
      "devices": [
        {
          "if": "HW",
          "label": "OPM",
          "plugin": "FitomEmuIF",
          "type": "FMHWIF",
          "engine": "YMEngine",
          "chip": "OPM",
          "index": 0,
          "pan": 0
        },
        {
          "if": "HW",
          "label": "OPL3",
          "plugin": "FitomEmuIF",
          "type": "FMHWIF",
          "engine": "YMEngine",
          "chip": "OPL3",
          "index": 0,
          "pan": 0
        },
        {
          "if": "HW",
          "label": "SSG",
          "plugin": "FitomEmuIF",
          "type": "FMHWIF",
          "engine": "AYEngine",
          "chip": "SSG",
          "index": 0,
          "pan": 0
        }
      ],
      "midi_inputs": [
        "MIDI キーボード"
      ]
    },
    {
      "profile_name": "自宅スタジオ (SPFM + OPN2エミュ)",
      "hw_plugins": [
        {
          "name": "FitomEmuIF",
          "dll": "FitomEmuIF.dll"
        },
        {
          "name": "SpfmDriver",
          "dll": "fitom_hw_spfm.dll"
        }
      ],
      "devices": [
        {
          "if": "HW",
          "label": "OPNA (SPFM slot0)",
          "plugin": "SpfmDriver",
          "type": "SPFM_TOWER",
          "port": "COM3",
          "slot": 0,
          "hw_clock": 3993600,
          "pan": 0
        },
        {
          "if": "HW",
          "label": "OPM (SPFM slot1)",
          "plugin": "SpfmDriver",
          "type": "SPFM_TOWER",
          "port": "COM3",
          "slot": 1,
          "hw_clock": 3579545,
          "pan": 0
        },
        {
          "if": "HW",
          "label": "OPN2 (エミュ)",
          "plugin": "FitomEmuIF",
          "type": "FMHWIF",
          "engine": "YMEngine",
          "chip": "OPN2",
          "index": 0,
          "pan": 0
        }
      ],
      "midi_inputs": [
        "UM-ONE"
      ]
    }
  ]
}
